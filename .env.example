# DeepSeek API key — get one at https://platform.deepseek.com/api_keys
# Copy this file to `.env` and fill in your key. Bun auto-loads `.env`.
DEEPSEEK_API_KEY=

# Optional: which DeepSeek model to use (default: deepseek-v4-flash).
# Use deepseek-reasoner to see the model's reasoning stream.
# DEEPSEEK_MODEL=deepseek-v4-flash
